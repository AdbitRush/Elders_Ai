                game_solitaire_title: "Pyramid Solitaire",
                game_solitaire_desc: "Find pairs of cards that add up to 13. Great math practice.",
                game_trivia_title: "General Trivia",
                game_trivia_desc: "A fun and light general knowledge quiz to stay sharp.",

                inst_memory: "Find all the matching pairs",
