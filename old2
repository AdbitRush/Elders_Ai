                inst_math: "Select the correct answer",
                inst_words: "Click the letters to find the hidden words",
                inst_simon: "Repeat the sequence by clicking the colors",
                inst_sudoku: "Select an empty square and click the matching number",
                inst_shapes: "Click a shape, then click its correct empty slot",
                inst_solitaire: "Select two cards that add up to 13 (Kings are 13 alone)",
                inst_trivia: "Select the correct answer from the options below",

                win_title: "Well Done!",
                win_generic: "You completed this level! Ready for the next one?",

                ws_pool: ["PEACE", "GOLD", "LOVE", "BOOK", "SUN", "FAMILY", "HEALTH", "SMILE", "SPRING", "HOPE", "LIGHT", "DREAM", "MUSIC", "FLOWER", "HAPPY"],
                trivia_pool: [
                    { q: "What is the largest ocean on Earth?", opts: ["Atlantic", "Indian", "Pacific", "Arctic"], a: 2 },
                    { q: "Who was the first person to walk on the moon?", opts: ["Yuri Gagarin", "Neil Armstrong", "Buzz Aldrin", "John Glenn"], a: 1 },
                    { q: "Which planet is known as the Red Planet?", opts: ["Venus", "Mars", "Jupiter", "Saturn"], a: 1 },
                    { q: "How many hours are in a day?", opts: ["12", "24", "48", "60"], a: 1 },
                    { q: "What is the capital of France?", opts: ["London", "Berlin", "Madrid", "Paris"], a: 3 },
                    { q: "How many days in a week?", opts: ["5", "6", "7", "8"], a: 2 }
                ]
            }
        };

        let currentLang = 'he';
        let gameState = { active: false, currentId: null };

        // Massive reusable asset pools for procedural generation
        const ALL_EMOJIS = ['🌿', '🎻', '🏺', '⛵', '🏠', '🍎', '🌻', '🚗', '🎸', '🚲', '🐶', '🐱', '🦋', '⚽', '🎨', '🚀', '⭐', '🎈', '🎁', '🎂'];
        const SHAPE_EMOJIS = ['⚪','🟦','🔺','⭐','♦️','🟩','🌙','❤️','💠','🔶'];
        const ODD_SETS = [['🚗','🚙','🚕'], ['🌻','🌼','🏵️'], ['😸','😹','😺'], ['🍎','🍅','🍒'], ['🟩','🟢','⬛'], ['🌞','🌝','☀️'], ['📘','📗','📕'], ['🌲','🌳','🌴']];

        // Utility: Array shuffler
        function shuffle(array) {
            let currentIndex = array.length, randomIndex;
            while (currentIndex != 0) {
                randomIndex = Math.floor(Math.random() * currentIndex);
                currentIndex--;
                [array[currentIndex], array[randomIndex]] = [array[randomIndex], array[currentIndex]];
            }
            return array;
        }

        function changeLanguage(lang) {
            currentLang = lang;
            document.documentElement.lang = lang;
            document.documentElement.dir = lang === 'he' ? 'rtl' : 'ltr';
            
            document.querySelectorAll('[data-i18n]').forEach(el => {
                const key = el.getAttribute('data-i18n');
                if (i18nData[lang][key]) {
                    el.innerText = i18nData[lang][key];
                }
            });

            if (gameState.active) {
                // Keep playing, just translate static strings. Data might be in old lang until next level.
                updateLevelDisplay();
            }
        }

        function t(key) {
            return i18nData[currentLang][key] || key;
        }

        function updateLevelDisplay() {
            const ind = document.getElementById('levelIndicator');
            if (gameState.active && gameState[gameState.currentId] && gameState[gameState.currentId].level) {
                ind.innerText = `${t('level_str')} ${gameState[gameState.currentId].level}`;
                ind.classList.remove('hidden');
            } else {
                ind.classList.add('hidden');
            }
        }

        // --- Navigation ---
        function showHome() {
            document.getElementById('homeScreen').classList.remove('hidden');
            document.getElementById('hero').classList.remove('hidden');
            document.getElementById('gameView').classList.add('hidden');
            document.getElementById('backBtn').classList.add('hidden');
            document.getElementById('modal').classList.add('hidden');
            document.getElementById('levelIndicator').classList.add('hidden');
            gameState.active = false; 
            gameState.currentId = null;
        }

        function loadGame(gameId, level = 1) {
            document.getElementById('homeScreen').classList.add('hidden');
            document.getElementById('hero').classList.add('hidden');
            document.getElementById('gameView').classList.remove('hidden');
            document.getElementById('backBtn').classList.remove('hidden');
            if(level === 1) window.scrollTo(0,0);

            const content = document.getElementById('gameContent');
            content.innerHTML = ''; 
            gameState.active = true;
            gameState.currentId = gameId;

            // Initialize level state if not exists
            if (!gameState[gameId] || level === 1) {
                gameState[gameId] = { level: level };
            } else {
                gameState[gameId].level = level;
            }

            updateLevelDisplay();

            const titleMap = {
                'memory': 'game_memory_title', 'oddoneout': 'game_odd_title',
                'math': 'game_math_title', 'wordsearch': 'game_words_title',
                'simon': 'game_simon_title', 'sudoku': 'game_sudoku_title',
                'shapes': 'game_shapes_title', 'solitaire': 'game_solitaire_title',
                'trivia': 'game_trivia_title'
            };
            const instMap = {
                'memory': 'inst_memory', 'oddoneout': 'inst_odd',
                'math': 'inst_math', 'wordsearch': 'inst_words',
                'simon': 'inst_simon', 'sudoku': 'inst_sudoku',
                'shapes': 'inst_shapes', 'solitaire': 'inst_solitaire',
                'trivia': 'inst_trivia'
            };
            
            document.getElementById('gameTitle').innerText = t(titleMap[gameId]);
            document.getElementById('gameInstructions').innerText = t(instMap[gameId]);

            // Launch Game Setup Logic
            if(gameId === 'memory') initMemory(content);
            if(gameId === 'oddoneout') initOddOneOut(content);
            if(gameId === 'math') initMath(content);
            if(gameId === 'wordsearch') initWordSearch(content);
            if(gameId === 'simon') initSimon(content);
            if(gameId === 'sudoku') initSudoku(content);
            if(gameId === 'shapes') initShapes(content);
            if(gameId === 'solitaire') initSolitaire(content);
            if(gameId === 'trivia') initTrivia(content);
        }

        function levelComplete() {
            if(!gameState.active) return;
            const modal = document.getElementById('modal');
            document.getElementById('modalTitle').innerText = t('win_title');
            document.getElementById('modalBody').innerText = t('win_generic');
            
            const nextBtn = document.getElementById('nextLevelBtn');
            nextBtn.onclick = () => {
                modal.classList.add('hidden');
                loadGame(gameState.currentId, gameState[gameState.currentId].level + 1);
            };
            
            modal.classList.remove('hidden');
        }

        // --- 1. Memory (Infinite Levels) ---
        function initMemory(container) {
            let state = gameState.memory;
            // Increase pairs with level (min 3, max 10 to fit screen comfortably)
            state.pairs = Math.min(3 + Math.floor(state.level / 2), 10);
            state.flipped = [];
            state.matched = 0;
            
            const selectedIcons = shuffle([...ALL_EMOJIS]).slice(0, state.pairs);
            const cards = shuffle([...selectedIcons, ...selectedIcons]);
            
            let html = `<div class="grid grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4 w-full max-w-2xl">`;
            cards.forEach((icon, i) => {
                html += `
                    <div class="aspect-square relative text-3xl md:text-5xl">
                        <div class="card-inner w-full h-full" data-val="${icon}" id="m-card-${i}" onclick="flipMemory(${i})">
                            <div class="card-face w-full h-full absolute bg-slate-700 text-white font-bold rounded-xl shadow-md">?</div>
                            <div class="card-face card-back w-full h-full absolute bg-white border-4 border-slate-700 rounded-xl shadow-md">${icon}</div>
                        </div>
                    </div>`;
            });
            html += `</div>`;
            container.innerHTML = html;
        }

        function flipMemory(i) {
            const card = document.getElementById(`m-card-${i}`);
            const state = gameState.memory;
            if (state.flipped.length === 2 || card.classList.contains('flipped') || card.classList.contains('matched')) return;

            card.classList.add('flipped');
            state.flipped.push(card);

            if (state.flipped.length === 2) {
                const [c1, c2] = state.flipped;
                if (c1.dataset.val === c2.dataset.val) {
                    c1.classList.add('matched'); c2.classList.add('matched');
                    state.matched++;
                    state.flipped = [];
                    if (state.matched === state.pairs) setTimeout(() => levelComplete(), 600);
                } else {
                    setTimeout(() => {
                        c1.classList.remove('flipped'); c2.classList.remove('flipped');
                        state.flipped = [];
                    }, 1000);
                }
            }
        }

        // --- 2. Odd One Out (Infinite Levels) ---
        function initOddOneOut(container) {
            let state = gameState.oddoneout;
            
            // Generate dynamic set
            const p = ODD_SETS[Math.floor(Math.random() * ODD_SETS.length)];
            const mainEmoji = p[0];
            const oddEmoji = p[Math.floor(Math.random() * (p.length-1)) + 1];
            
            const gridSize = 16; // fixed 4x4 for visual consistency
            const oddIndex = Math.floor(Math.random() * gridSize);
            
            let html = `<div class="grid grid-cols-4 gap-4 bg-gray-50 p-6 rounded-2xl border">`;
            for(let i=0; i<gridSize; i++) {
                const isOdd = (i === oddIndex);
                const emoji = isOdd ? oddEmoji : mainEmoji;
                html += `<div onclick="clickOdd(${isOdd})" class="w-16 h-16 md:w-20 md:h-20 bg-white border shadow-sm rounded-xl flex items-center justify-center text-4xl md:text-5xl cursor-pointer hover:bg-amber-50 transition transform hover:scale-105">${emoji}</div>`;
            }
            html += `</div>`;
            container.innerHTML = html;
        }

        function clickOdd(isOdd) {
            if(isOdd) {
                levelComplete();
            } else {
                const container = document.getElementById('gameContent').firstElementChild;
                container.classList.add('bg-red-50');
                setTimeout(() => container.classList.remove('bg-red-50'), 300);
            }
        }

        // --- 3. Quick Math (Infinite Levels) ---
        function initMath(container) {
            let state = gameState.math;
            
            // Difficulty scales with level
            const maxVal = 10 + (state.level * 3);
            const isAddition = Math.random() > 0.4;
            
            let a, b, answer;
            if(isAddition) {
                a = Math.floor(Math.random() * maxVal) + 1;
                b = Math.floor(Math.random() * maxVal) + 1;
                answer = a + b;
            } else {
                a = Math.floor(Math.random() * maxVal) + 5;
                b = Math.floor(Math.random() * a); 
                answer = a - b;
            }

            const symbol = isAddition ? '+' : '-';
            const questionStr = `${a} ${symbol} ${b} = ?`;

            let options = new Set();
            options.add(answer);
            while(options.size < 4) {
                let fake = answer + (Math.floor(Math.random() * 7) - 3);
                if(fake >= 0 && fake !== answer) options.add(fake);
            }
            const optsArr = shuffle(Array.from(options));

            let html = `<div class="text-6xl font-bold mb-10 text-slate-800" dir="ltr">${questionStr}</div>`;
            html += `<div class="grid grid-cols-2 gap-6 w-full max-w-sm">`;
            optsArr.forEach(opt => {
                html += `<button onclick="answerMath(${opt}, ${answer})" class="bg-blue-50 border-2 border-blue-200 hover:border-blue-500 text-3xl font-bold py-6 rounded-2xl transition shadow-sm">${opt}</button>`;
            });
            html += `</div>`;
            container.innerHTML = html;
        }

        function answerMath(selected, correct) {
            if(selected === correct) {
                levelComplete();
            } else {
                event.target.classList.replace('bg-blue-50', 'bg-red-100');
                event.target.classList.replace('border-blue-200', 'border-red-300');
                setTimeout(() => {
                    event.target.classList.replace('bg-red-100', 'bg-blue-50');
                    event.target.classList.replace('border-red-300', 'border-blue-200');
                }, 500);
            }
        }

        // --- 4. Word Search (Procedural Generation) ---
        function initWordSearch(container) {
            let state = gameState.wordsearch;
            const fullPool = i18nData[currentLang].ws_pool;
            // Pick 4-5 words
            const wordsCount = Math.min(4 + Math.floor(state.level / 3), 6);
            const selectedWords = shuffle([...fullPool]).slice(0, wordsCount);
            
            const size = 6 + Math.min(Math.floor(state.level / 5), 2); // 6x6, max 8x8
            let grid = Array(size).fill(null).map(()=>Array(size).fill(''));
            
            // Simple generator: place horizontally or vertically
            selectedWords.forEach(word => {
                let placed = false;
                let attempts = 0;
                while(!placed && attempts < 50) {
                    const isHoriz = Math.random() > 0.5;
                    const r = Math.floor(Math.random() * size);
                    const c = Math.floor(Math.random() * size);
                    
                    if(isHoriz && c + word.length <= size) {
                        let canPlace = true;
                        for(let i=0; i<word.length; i++) if(grid[r][c+i] !== '' && grid[r][c+i] !== word[i]) canPlace = false;
                        if(canPlace) {
                            for(let i=0; i<word.length; i++) grid[r][c+i] = word[i];
                            placed = true;
                        }
                    } else if (!isHoriz && r + word.length <= size) {
                        let canPlace = true;
                        for(let i=0; i<word.length; i++) if(grid[r+i][c] !== '' && grid[r+i][c] !== word[i]) canPlace = false;
                        if(canPlace) {
                            for(let i=0; i<word.length; i++) grid[r+i][c] = word[i];
                            placed = true;
                        }
                    }
                    attempts++;
                }
            });

            // Fill empty
            const alphabet = currentLang === 'he' ? 'אבגדהוזחטיכלמנסעפצקרשת' : 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
            for(let r=0; r<size; r++) {
                for(let c=0; c<size; c++) {
                    if(grid[r][c] === '') grid[r][c] = alphabet[Math.floor(Math.random() * alphabet.length)];
                }
            }

            state.selectedCells = [];
            state.foundWords = 0;
            state.words = selectedWords;

            let html = `<div class="flex flex-col md:flex-row gap-10 items-center">
                <div class="bg-white border-4 border-slate-800 p-2 md:p-6 rounded-xl shadow-lg">
                    <div class="grid gap-2 text-2xl md:text-3xl font-bold font-mono" style="grid-template-columns: repeat(${size}, minmax(0, 1fr));">`;
            
            grid.forEach((row, r) => {
                row.forEach((letter, c) => {
                    html += `<div class="ws-cell w-10 h-10 md:w-14 md:h-14 flex items-center justify-center border border-gray-200 rounded-lg bg-gray-50 hover:bg-gray-200" 
                                  onclick="clickWsCell(this, '${letter}')">${letter}</div>`;
                });
            });

            html += `</div></div><div class="flex flex-col gap-3 text-xl font-bold w-48 text-center" id="ws-wordlist">`;
            selectedWords.forEach(w => {
                html += `<div class="bg-gray-100 p-3 rounded-lg border text-gray-500 transition-colors" id="word-${w}">${w}</div>`;
            });
            html += `</div></div>`;
            container.innerHTML = html;
        }

        function clickWsCell(el, letter) {
            if(el.classList.contains('found')) return;
            if(el.classList.contains('selected')) {
                el.classList.remove('selected');
                gameState.wordsearch.selectedCells = gameState.wordsearch.selectedCells.filter(c => c.el !== el);
            } else {
                el.classList.add('selected');
                gameState.wordsearch.selectedCells.push({el: el, char: letter});
            }
            checkWordSearch();
        }

        function checkWordSearch() {
            const state = gameState.wordsearch;
            const currentStr = state.selectedCells.map(c => c.char).join('');
            const currentStrRev = state.selectedCells.map(c => c.char).reverse().join('');
            
            let matchedWord = null;
            if(state.words.includes(currentStr)) matchedWord = currentStr;
            if(state.words.includes(currentStrRev)) matchedWord = currentStrRev;

            if(matchedWord) {
                state.selectedCells.forEach(c => {
                    c.el.classList.remove('selected');
                    c.el.classList.add('found');
                });
                document.getElementById(`word-${matchedWord}`).classList.replace('bg-gray-100', 'bg-green-100');
                document.getElementById(`word-${matchedWord}`).classList.replace('text-gray-500', 'text-green-700');
                
                state.words = state.words.filter(w => w !== matchedWord);
                state.selectedCells = [];
                state.foundWords++;
                
                // End level if all found
                if(state.words.length === 0) {
                    setTimeout(() => levelComplete(), 500);
                }
            }
        }

        // --- 5. Simon (Infinite Sequences) ---
        function initSimon(container) {
            // Keep the same sequence across levels during a single play session
            if(!gameState.simon.sequence) {
                gameState.simon.sequence = [];
            }
            gameState.simon.userIndex = 0;
            gameState.simon.waitingForUser = false;
            
            const colors = [
                {id: 0, c: 'bg-red-500'}, {id: 1, c: 'bg-blue-500'}, 
                {id: 2, c: 'bg-green-500'}, {id: 3, c: 'bg-yellow-400'}
            ];

            let html = `<div class="grid grid-cols-2 gap-4 max-w-xs mx-auto">`;
            colors.forEach(col => {
                html += `<div id="simon-${col.id}" class="simon-btn w-24 h-24 md:w-32 md:h-32 rounded-2xl ${col.c}" onclick="clickSimon(${col.id})"></div>`;
            });
            html += `</div>`;
            
            container.innerHTML = html;
            setTimeout(() => playSimonSequence(), 800);
        }

        async function playSimonSequence() {
            if(!gameState.active) return;
            const state = gameState.simon;
            state.waitingForUser = false;
            state.userIndex = 0;
            
            // Add new color to sequence
            state.sequence.push(Math.floor(Math.random() * 4));
            
            for(let i=0; i<state.sequence.length; i++) {
                if(!gameState.active) return;
                await new Promise(r => setTimeout(r, 500));
                await flashSimon(state.sequence[i]);
            }
            
            if(!gameState.active) return;
            state.waitingForUser = true;
        }

        async function flashSimon(id) {
            if(!gameState.active) return;
            const el = document.getElementById(`simon-${id}`);
            el.classList.add('active');
            await new Promise(r => setTimeout(r, 400));
            el.classList.remove('active');
        }

        function clickSimon(id) {
            const state = gameState.simon;
            if(!state.waitingForUser) return;
            
            flashSimon(id);
            
            if(id === state.sequence[state.userIndex]) {
                state.userIndex++;
                if(state.userIndex === state.sequence.length) {
                    state.waitingForUser = false;
                    setTimeout(() => levelComplete(), 500); // Win level, move to next
                }
            } else {
                // Mistake
                state.waitingForUser = false;
                state.sequence.pop(); // Remove the latest
                const container = document.getElementById('gameContent').firstElementChild;
                container.classList.add('animate-pulse', 'bg-red-100');
                setTimeout(() => {
                    container.classList.remove('animate-pulse', 'bg-red-100');
                    playSimonSequence(); // replay without advancing level
                }, 1000);
            }
        }

        // --- 6. Sudoku (Procedural Shuffler) ---
        function initSudoku(container) {
            // Base valid solution
            const baseSolution = [
                [1, 4, 3, 2],
                [2, 3, 4, 1],
                [3, 1, 4, 2],
                [4, 2, 1, 3]
            ];
            
            // Shuffle numbers mapping (e.g. 1 becomes 3) -> preserves validity!
            const nums = shuffle([1, 2, 3, 4]);
            const map = {1: nums[0], 2: nums[1], 3: nums[2], 4: nums[3]};
            
            let solution = [
                [map[1], map[4], map[3], map[2]],
                [map[2], map[3], map[4], map[1]],
                [map[3], map[1], map[4], map[2]],
                [map[4], map[2], map[1], map[3]]
            ];

            // Remove items based on level
            let puzzle = JSON.parse(JSON.stringify(solution));
            const holes = Math.min(4 + gameState.sudoku.level, 10);
            let removed = 0;
            while(removed < holes) {
                let r = Math.floor(Math.random() * 4);
                let c = Math.floor(Math.random() * 4);
                if(puzzle[r][c] !== 0) {
                    puzzle[r][c] = 0;
                    removed++;
                }
            }

            gameState.sudoku.puzzle = puzzle;
            gameState.sudoku.solution = solution;
            gameState.sudoku.selectedRow = -1;
            gameState.sudoku.selectedCol = -1;

            let html = `<div class="flex flex-col items-center gap-8">
                <div class="grid grid-cols-4 gap-1 bg-slate-800 p-2 rounded-xl">`;
            
            for(let r=0; r<4; r++){
                for(let c=0; c<4; c++){
                    const val = puzzle[r][c];
                    const classes = val !== 0 ? 'fixed' : '';
                    const display = val !== 0 ? val : '';
                    html += `<div id="sudo-${r}-${c}" class="sudoku-cell ${classes} w-16 h-16 md:w-20 md:h-20 bg-white flex items-center justify-center text-3xl font-bold rounded-sm"
                                  onclick="selectSudoku(${r},${c})">${display}</div>`;
                }
            }
            html += `</div><div class="flex gap-4">`;
            for(let i=1; i<=4; i++){
                html += `<button onclick="fillSudoku(${i})" class="w-16 h-16 bg-blue-100 border-2 border-blue-300 rounded-xl text-3xl font-bold text-blue-800 hover:bg-blue-200">${i}</button>`;
            }
            html += `</div></div>`;
            container.innerHTML = html;
        }

        function selectSudoku(r, c) {
            if(gameState.sudoku.puzzle[r][c] !== 0) return;
            document.querySelectorAll('.sudoku-cell').forEach(el => el.classList.remove('selected'));
            document.getElementById(`sudo-${r}-${c}`).classList.add('selected');
            gameState.sudoku.selectedRow = r;
            gameState.sudoku.selectedCol = c;
        }

        function fillSudoku(num) {
            const r = gameState.sudoku.selectedRow;
            const c = gameState.sudoku.selectedCol;
            if(r === -1 || c === -1) return;

            const el = document.getElementById(`sudo-${r}-${c}`);
            el.innerText = num;
            
            if(gameState.sudoku.solution[r][c] === num) {
                el.classList.remove('error', 'selected');
                el.classList.add('text-green-600');
                
                // check win
                let win = true;
                for(let row=0; row<4; row++){
                    for(let col=0; col<4; col++){
                        if(document.getElementById(`sudo-${row}-${col}`).innerText != gameState.sudoku.solution[row][col]) win = false;
                    }
                }
                if(win) setTimeout(() => levelComplete(), 500);

            } else {
                el.classList.add('error');
            }
        }

        // --- 7. Shapes (Infinite Levels) ---
        function initShapes(container) {
            let state = gameState.shapes;
            const count = Math.min(4 + Math.floor(state.level/3), 8);
            const items = shuffle([...SHAPE_EMOJIS]).slice(0, count).map((icon, id) => ({id, icon}));
            
            state.selected = null;
            state.placed = 0;
            state.total = count;
            
            let gridClass = count > 4 ? 'grid-cols-3 md:grid-cols-4' : 'grid-cols-2';

            let html = `
                <div class="flex flex-col md:flex-row justify-around w-full items-center gap-10">
                    <div id="shapePick" class="grid ${gridClass} gap-6">
                        ${items.map(i => `<div onclick="selectShape(${i.id}, this)" class="w-16 h-16 md:w-20 md:h-20 bg-white border-4 border-gray-200 rounded-2xl flex items-center justify-center text-3xl md:text-4xl cursor-pointer hover:border-amber-500 transition shadow-sm">${i.icon}</div>`).join('')}
                    </div>
                    <div class="text-5xl text-gray-300 hidden md:block">${currentLang==='he'?'⬅️':'➡️'}</div>
                    <div id="shapeDrop" class="grid ${gridClass} gap-6">
                        ${shuffle([...items]).map(i => `<div onclick="dropShape(${i.id}, this)" class="w-16 h-16 md:w-20 md:h-20 border-4 border-dashed border-gray-300 rounded-2xl flex items-center justify-center text-2xl font-bold cursor-pointer"></div>`).join('')}
                    </div>
                </div>`;
            container.innerHTML = html;
        }

        function selectShape(id, el) {
            document.querySelectorAll('#shapePick div').forEach(d => d.classList.remove('border-amber-500', 'bg-amber-50'));
            el.classList.add('border-amber-500', 'bg-amber-50');
            gameState.shapes.selected = { id, icon: el.innerText, el };
        }

        function dropShape(id, el) {
            const state = gameState.shapes;
            if (state.selected && state.selected.id === id) {
                el.innerText = state.selected.icon;
                el.classList.remove('border-dashed');
                el.classList.add('border-solid', 'border-green-500', 'bg-green-50');
                state.selected.el.style.visibility = 'hidden';
                state.selected = null;
                state.placed++;
                
                if (state.placed === state.total) setTimeout(() => levelComplete(), 500);
            }
        }

        // --- 8. Solitaire (Procedural Pyramid) ---
        function initSolitaire(container) {
            let state = gameState.solitaire;
            
            // Base pairs that sum to 13
            const pairOptions = [[1,12],[2,11],[3,10],[4,9],[5,8],[6,7],[13,13]];
            
            // Draw N pairs based on level
            const pairsCount = Math.min(5 + state.level, 10);
            let drawnCards = [];
            for(let i=0; i<pairsCount; i++) {
                const pair = pairOptions[Math.floor(Math.random() * pairOptions.length)];
                drawnCards.push(pair[0]);
                // If it's a King(13), it clears itself, no need to force a second 13 unless we want pairs of kings.
                // For simplicity, we just add the exact pair values.
                if(pair[0] !== 13) drawnCards.push(pair[1]); 
            }

            const deck = shuffle(drawnCards).map(v => {
                let display = v;
                if(v==1) display = 'A'; if(v==11) display = 'J'; if(v==12) display = 'Q'; if(v==13) display = 'K';
                return { val: v, label: display, suit: Math.random()>0.5?'♥':'♠' };
            });

            state.cards = deck;
            state.selected = null;
            state.removed = 0;

            let html = `<div class="grid grid-cols-4 md:grid-cols-6 lg:grid-cols-7 gap-3">`;
            deck.forEach((card, i) => {
                const color = card.suit === '♥' ? 'red-suit' : 'black-suit';
                html += `<div id="sol-card-${i}" class="playing-card w-16 h-24 md:w-20 md:h-28 text-2xl md:text-3xl ${color}" onclick="clickSolitaire(${i})">
                            <div class="flex flex-col items-center">
                                <span>${card.label}</span>
                                <span class="text-xl md:text-2xl">${card.suit}</span>
                            </div>
                         </div>`;
            });
            html += `</div>`;
            container.innerHTML = html;
        }

        function clickSolitaire(i) {
            const state = gameState.solitaire;
            const el = document.getElementById(`sol-card-${i}`);
            const card = state.cards[i];

            if(el.style.visibility === 'hidden') return;

            if(card.val === 13) {
                el.style.visibility = 'hidden';
                state.removed++; // 1 card removed
                checkSolitaireWin();
                return;
            }

            if(!state.selected) {
                state.selected = { index: i, el, val: card.val };
                el.classList.add('selected');
            } else {
                if(state.selected.index === i) {
                    el.classList.remove('selected');
                    state.selected = null;
                } else if(state.selected.val + card.val === 13) {
                    el.style.visibility = 'hidden';
                    state.selected.el.style.visibility = 'hidden';
                    state.selected = null;
                    state.removed += 2; // 2 cards removed
                    checkSolitaireWin();
                } else {
                    state.selected.el.classList.remove('selected');
                    state.selected = { index: i, el, val: card.val };
                    el.classList.add('selected');
                }
            }
        }

        function checkSolitaireWin() {
            if(gameState.solitaire.removed >= gameState.solitaire.cards.length) {
                setTimeout(() => levelComplete(), 500);
            }
        }

        // --- 9. Trivia (Infinite loops from pool) ---
        function initTrivia(container) {
            let state = gameState.trivia;
            const pool = i18nData[currentLang].trivia_qs;
            
            // Randomly select 4 questions for this level
            state.questions = shuffle([...pool]).slice(0, 4);
            state.current = 0;
            
            renderTriviaQuestion(container);
        }

        function renderTriviaQuestion(container) {
            if(!gameState.active) return;
            const state = gameState.trivia;
            
            if(state.current >= state.questions.length) {
                levelComplete();
                return;
            }

            const q = state.questions[state.current];
            let html = `
                <div class="max-w-xl w-full">
                    <div class="text-sm font-bold text-gray-400 mb-2">${currentLang==='he'?'שאלה':'Question'} ${state.current+1} / ${state.questions.length}</div>
                    <h3 class="text-2xl md:text-3xl font-bold mb-8 text-center text-[#1a365d] bg-blue-50 p-6 rounded-xl">${q.q}</h3>
                    <div class="flex flex-col gap-4">
            `;
            q.opts.forEach((opt, idx) => {
                html += `<button onclick="answerTrivia(${idx}, ${q.a})" class="bg-white border-2 border-gray-200 hover:border-[#b7791f] text-xl p-4 rounded-xl text-right md:text-center transition shadow-sm">${opt}</button>`;
            });
            html += `</div></div>`;
            container.innerHTML = html;
        }

        function answerTrivia(selectedIdx, correctIdx) {
            const state = gameState.trivia;
            const isCorrect = selectedIdx === correctIdx;
            
            // Visual feedback
            event.target.classList.replace('border-gray-200', isCorrect ? 'border-green-500' : 'border-red-500');
            event.target.classList.add(isCorrect ? 'bg-green-50' : 'bg-red-50');
            
            setTimeout(() => {
                state.current++;
                renderTriviaQuestion(document.getElementById('gameContent'));
            }, 600);
        }

        // Initialize
        changeLanguage('he');
    </script>
</body>
</html>
